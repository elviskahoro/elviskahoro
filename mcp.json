{
  "mcpServers": {
    "notion": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.notion.com/mcp"]
    },
    "linear": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.linear.app/mcp"],
      "env": {
        "LINEAR_API_KEY": "${op://Personal/api-linear/credential}"
      }
    },
    "resend": {
      "command": "npx",
      "args": ["-y", "resend-mcp"],
      "env": {
        "RESEND_API_KEY": "${op://Personal/api-resend/credential}"
      }
    },
    "dosu": {
      "type": "http",
      "url": "https://api.dosu.dev/v1/mcp/deployments/d23fd603-faca-4166-8ba5-71414c8a9d81",
      "headers": {
        "X-Dosu-API-Key": "${op://Personal/api-dosu/credential}"
      }
    }
  }
}
