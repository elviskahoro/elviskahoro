{
  "editor.fontFamily": "MonoLisa",
  "editor.accessibilitySupport": "off",
  "editor.autoClosingBrackets": "never",
  "editor.bracketPairColorization.enabled": true,
  "editor.autoSurround": "never",
  "editor.fontSize": 16,
  "editor.lineHeight": 26,
  "editor.autoClosingQuotes": "never",
  "editor.autoClosingDelete": "never",
  "editor.autoClosingOvertype": "never",
  "editor.cursorSurroundingLines": 7,
  "editor.renderWhitespace": "boundary",
  "editor.tabCompletion": "on",
  "editor.inlayHints.padding": true,
  "editor.inlayHints.fontFamily": "MonoLisa",
  "editor.linkedEditing": true,
  "editor.suggest.localityBonus": true,
  "editor.suggest.preview": true,
  "editor.suggest.shareSuggestSelections": true,
  "editor.suggest.showStatusBar": true,
  "editor.minimap.showSlider": "always",
  "editor.minimap.size": "fill",
  "editor.stickyScroll.enabled": true,
  "editor.stickyScroll.maxLineCount": 6,
  "editor.stickyTabStops": true,
  "editor.detectIndentation": false,
  "editor.hover.sticky": false,
  "editor.lineNumbers": "relative",
  "editor.defaultFormatter": "trunk.io",
  "editor.acceptSuggestionOnCommitCharacter": false,
  "editor.inlineSuggest.enabled": true,
  "editor.inlineSuggest.suppressSuggestions": true,
  "workbench.colorTheme": "Monokai Pro (Filter Spectrum)",
  "workbench.preferredDarkColorTheme": "Monokai Pro (Filter Spectrum)",
  "workbench.activityBar.iconClickBehavior": "focus",
  "workbench.activityBar.location": "top",
  "workbench.tree.renderIndentGuides": "always",
  "workbench.editor.autoLockGroups": {
    "terminalEditor": false
  },
  "workbench.editor.highlightModifiedTabs": true,
  "workbench.editor.tabCloseButton": "off",
  "workbench.editor.tabActionCloseVisibility": false,
  "workbench.editor.focusRecentEditorAfterClose": false,
  "workbench.editor.enablePreview": false,
  "workbench.startupEditor": "none",
  "workbench.sideBar.location": "right",
  "workbench.iconTheme": "Monokai Pro (Filter Spectrum) Icons",
  "workbench.list.smoothScrolling": true,
  "workbench.reduceMotion": "on",
  "workbench.fontAliasing": "auto",
  "workbench.colorCustomizations": {},
  "window.restoreWindows": "none",
  "explorer.confirmUndo": "light",
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.autoReveal": false,
  "explorer.compactFolders": false,
  "telemetry.telemetryLevel": "off",
  "security.workspace.trust.untrustedFiles": "open",
  "security.promptForLocalFileProtocolHandling": false,
  "html.autoCreateQuotes": false,
  "emmet.triggerExpansionOnTab": true,
  "git.suggestSmartCommit": false,
  "git.confirmSync": false,
  "git.autofetch": "all",
  "git.openRepositoryInParentFolders": "never",
  "terminal.integrated.altClickMovesCursor": false,
  "terminal.external.osxExec": "Warp.app",
  "diffEditor.codeLens": true,
  "diffEditor.renderSideBySide": false,
  "debug.openDebug": "neverOpen",
  "files.trimTrailingWhitespace": true,
  "files.exclude": {
    "**/.trunk/*out": true,
    "**/.trunk/*out/": true,
    "**/.trunk/*actions/": true,
    "**/.trunk/*logs/": true,
    "**/.trunk/*plugins/": true,
    "**/.trunk/*notifications/": true
  },
  "files.watcherExclude": {
    "**/.trunk/*out": true,
    "**/.trunk/*out/": true,
    "**/.trunk/*actions/": true,
    "**/.trunk/*logs/": true,
    "**/.trunk/*plugins/": true,
    "**/.trunk/*notifications/": true
  },
  "search.exclude": {
    ".gitignore": true,
    "**/warp/themes/": true,
    "**/warp/workflows/": true,
    "poetry.lock": true
  },
  "colorize.languages": [
    "css",
    "sass",
    "scss",
    "less",
    "postcss",
    "sss",
    "stylus",
    "xml",
    "svg",
    "vscode.yaml",
    "yaml",
    "YAML Language Basics",
    "[yaml]"
  ],
  "python.diagnostics.sourceMapsEnabled": true,
  "python.disableInstallationCheck": true,
  "python.terminal.activateEnvInCurrentTerminal": true,
  "python.languageServer": "Pylance",
  "python.defaultInterpreterPath": "/Users/elvis/.pyenv/versions/3.12.4/bin/python",
  "python.testing.cwd": "src/tests/",
  "python.testing.pytestPath": "/Users/elvis/.pyenv/shims/pytest",
  "[python]": {
    "editor.defaultFormatter": "trunk.io"
  },
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features",
    "editor.tabSize": 2
  },
  "[jsonc]": {
    "editor.defaultFormatter": "trunk.io"
  },
  "[html]": {
    "editor.defaultFormatter": "vscode.html-language-features"
  },
  "[sql]": {
    "editor.defaultFormatter": "adpyke.vscode-sql-formatter"
  },
  "projectManager.git.baseFolders": [
    "/Users/elvis/Code"
  ],
  "redhat.telemetry.enabled": false,
  "githubPullRequests.pullBranch": "never",
  "trunk.trunkGrayOutNonBlockingIssues": false,
  "trunk.inlineDecoratorsForAllExtensions": true,
  "trunk.trace.server": "verbose",
  "trunk.showPreexistingIssues": false,
  "todo-tree.general.enableFileWatcher": true,
  "todo-tree.general.statusBar": "current file",
  "todo-tree.general.tagGroups": {},
  "todo-tree.general.showActivityBarBadge": true,
  "todo-tree.general.statusBarClickBehaviour": "cycle",
  "todo-tree.general.revealBehaviour": "start of line",
  "todo-tree.filtering.excludeGlobs": [
    "**/node_modules",
    "**/pycord",
    "**/.swm",
    "**/src/pycord/*"
  ],
  "todo-tree.filtering.ignoreGitSubmodules": true,
  "todo-tree.filtering.includeHiddenFiles": true,
  "todo-tree.filtering.useBuiltInExcludes": "file and search excludes",
  "todo-tree.tree.showCountsInTree": true,
  "todo-tree.tree.groupedBySubTag": true,
  "todo-tree.tree.groupedByTag": true,
  "todo-tree.tree.expanded": true,
  "todo-tree.tree.flat": true,
  "todo-tree.highlights.enabled": false,
  "todo-tree.highlights.useColourScheme": true,
  "merge-conflict.autoNavigateNextConflict.enabled": true,
  "autoDocstring.docstringFormat": "one-line-sphinx",
  "autoDocstring.generateDocstringOnEnter": true,
  "autoDocstring.includeExtendedSummary": true,
  "autoDocstring.guessTypes": true,
  "autoDocstring.includeName": true,
  "markdownlint.config": {},
  "jupyter.interactiveWindow.creationMode": "perFile",
  "breadcrumbs.symbolSortOrder": "type",
  "outline.showConstants": false,
  "outline.showVariables": false,
  "extensions.autoUpdate": "onlyEnabledExtensions",
  "vim.mouseSelectionGoesIntoVisualMode": false,
  "vim.hlsearch": true,
  "vim.highlightedyank.enable": true,
  "vim.camelCaseMotion.enable": true,
  "vim.foldfix": true,
  "vim.showMarksInGutter": true,
  "vim.handleKeys": {
    "<C-s>": false,
    "<C-z>": false
  },
  "window.commandCenter": true,
  "cursorPreview.disableInlineCompletions": false,
  "cursorPreview.enableInlineCompletion": true
}
