// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      "shift-cmd-o": "file_finder::Toggle",
      "cmd-o": "file_finder::Toggle",
      // ctrl-alt-cmd-n creates a new file
      "ctrl-alt-cmd-n": "workspace::NewFile",
      // cmd-l toggles the agent panel
      "cmd-l": "agent::ToggleFocus",
      // cmd-1 / cmd-2 navigate previous/next tab globally (override default activate-by-index)
      "cmd-1": "pane::ActivatePreviousItem",
      "cmd-2": "pane::ActivateNextItem",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      // cmd-/+ fold/unfold in editor (overrides font zoom when editor is focused)
      "shift-cmd-o": "file_finder::Toggle",
      "cmd-o": "file_finder::Toggle",
      "cmd--": "editor::Fold",
      "cmd-=": "editor::UnfoldLines",
      // cmd-enter goes to definition (matches VSCode editor.action.revealDefinition)
      "cmd-enter": "editor::GoToDefinition",
      // shift-cmd-enter finds all references (matches VSCode shift+f12)
      "shift-cmd-enter": "editor::FindAllReferences",
      // alt-cmd-enter goes to implementation
      "alt-cmd-enter": "editor::GoToImplementation",
    },
  },
  {
    // cmd-l opens the agent panel and adds the current selection as context
    "context": "Editor && !agent_diff && !AgentPanel",
    "bindings": {
      "cmd-l": "agent::AddSelectionToThread",
    },
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      // shift-cmd-c copies the relative file path of selected file in file explorer
      "shift-cmd-c": "project_panel::CopyRelativePath",
    },
  },
]
