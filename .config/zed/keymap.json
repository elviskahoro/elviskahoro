// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      "shift-cmd-o": "outline::Toggle",
      "cmd-o": "file_finder::Toggle",
      // ctrl-alt-cmd-n creates a new file
      "ctrl-alt-cmd-n": "workspace::NewFile",
      // cmd-l focuses the agent panel (opens+focuses if closed/unfocused, unfocuses if focused)
      "cmd-l": "agent::ToggleFocus",
      // shift-cmd-b opens/closes the right dock (where the agent panel lives)
      "shift-cmd-b": "workspace::ToggleRightDock",
      // cmd-1 / cmd-2 navigate previous/next tab globally (override default activate-by-index)
      "cmd-1": "pane::ActivatePreviousItem",
      "cmd-2": "pane::ActivateNextItem",
      // zoom out with minus: ctrl-cmd, alt-cmd, shift-cmd, or ctrl-alt-cmd
      "ctrl-cmd--": "zed::DecreaseBufferFontSize",
      "alt-cmd--": "zed::DecreaseBufferFontSize",
      "shift-cmd--": "zed::DecreaseBufferFontSize",
      "ctrl-alt-cmd--": "zed::DecreaseBufferFontSize",
      // zoom in with plus: ctrl-cmd, alt-cmd, shift-cmd, or ctrl-alt-cmd
      "ctrl-cmd-=": "zed::IncreaseBufferFontSize",
      "alt-cmd-=": "zed::IncreaseBufferFontSize",
      "shift-cmd-=": "zed::IncreaseBufferFontSize",
      "ctrl-alt-cmd-=": "zed::IncreaseBufferFontSize",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      // cmd-/+ fold/unfold in editor (overrides font zoom when editor is focused)
      "shift-cmd-o": "outline::Toggle",
      "cmd-o": "file_finder::Toggle",
      "cmd--": "editor::Fold",
      "cmd-_": "editor::FoldRecursive",
      "cmd-=": "editor::UnfoldLines",
      "cmd-+": "editor::UnfoldRecursive",
      // cmd-enter goes to definition (matches VSCode editor.action.revealDefinition)
      "cmd-enter": "editor::GoToDefinition",
      // shift-cmd-enter finds all references (matches VSCode shift+f12)
      "shift-cmd-enter": "editor::FindAllReferences",
      // alt-cmd-enter goes to implementation
      "alt-cmd-enter": "editor::GoToImplementation",
    },
  },
  {
    // cmd-l opens/focuses the agent panel; if text is selected, also attaches it as context.
    // AddSelectionToThread no-ops without a selection, so we chain ToggleFocus first to
    // guarantee the panel opens either way. cmd-? and cmd-> are Zed defaults for these actions.
    "context": "Editor && !agent_diff && !AgentPanel",
    "bindings": {
      "cmd-l": ["workspace::SendKeystrokes", "cmd-? cmd->"],
    },
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      // shift-cmd-c copies the relative file path of selected file in file explorer
      "shift-cmd-c": "project_panel::CopyRelativePath",
    },
  },
]
