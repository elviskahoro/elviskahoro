// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      // cmd-o opens file finder instead of system open dialog (matches VSCode quickOpen)
      "cmd-o": "file_finder::Toggle",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      // cmd-/+ fold/unfold in editor (overrides font zoom when editor is focused)
      "cmd--": "editor::Fold",
      "cmd-=": "editor::UnfoldLines",
    },
  },
]
