  x         = checkout -
  count-lines= "!git log --author=\"$1\" --pretty=tformat: --numstat | awk '{ add += $1; subs += $2; loc += $1 - $2 } END { printf \"added lines: %s, removed lines: %s, total lines: %s\\n\", add, subs, loc }' #"

	cai = "!git commit -m \"$(git diff --cached | claude --print --model haiku --effort low --no-session-persistence --tools '' --disable-slash-commands 'Create a concise git commit message in conventional commits format (type: description). Return ONLY the message, nothing else.')\""
	ssai = "!BASE=$(git merge-base HEAD main) && DIFF=$(git diff \"$BASE\"..HEAD | head -3000) && LOG=$(git log --oneline \"$BASE\"..HEAD) && TITLE=$(printf \"Commits:\\n%s\\n\\nDiff (truncated):\\n%s\" \"$LOG\" \"$DIFF\" | claude --print --model haiku --effort low --no-session-persistence \"Given these commits and diff for a PR, create a concise PR title (under 70 chars, no quotes). Return ONLY the title, nothing else.\" 2>&1) && BODY=$(printf \"Commits:\\n%s\\n\\nDiff (truncated):\\n%s\" \"$LOG\" \"$DIFF\" | claude --print --model haiku --effort low --no-session-persistence \"Given these commits and diff for a PR, write a PR description in markdown with a ## Summary section (2-4 bullet points) and a ## Test plan section (checklist). Be concise. Return ONLY the markdown body, nothing else.\" 2>&1) && PR_URL=$(gh pr view --json url -q .url 2>/dev/null) && if [ -n \"$PR_URL\" ]; then gh pr edit --title \"$TITLE\" --body \"$BODY\" && echo \"Updated PR: $PR_URL\"; else gh pr create --title \"$TITLE\" --body \"$BODY\" --web; fi"

[init]
	defaultBranch = main

[fetch]
	prune = true

[pull]
	rebase = true

[push]
	default = simple
	autoSetupRemote = true

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge --skip -- %f
	process = git-lfs filter-process --skip
	required = true

[core]
	excludesfile = /Users/elvis/.gitignore_global
	editor = vim
	pager = delta

[delta]
	navigate = true    # use n and N to move between diff sections
	light = false      # set to true if you're in a terminal w/ a light background color (e.g. the default macOS terminal)
	line-numbers = true
	minus-style = red "#ffeeee"
	plus-style = green "#383830"
    side-by-side = false

[diff]
	colorMoved = default

[color]
	status = auto
	diff = auto
	branch = auto
	interactive = auto
	grep = auto
	ui = auto

[interactive]
    diffFilter = delta --color-only

[stash]
    showStat = true
    showPatch = true

[merge]
	conflictstyle = diff3

[http]
	cookiefile = ~/.config/.gitcookies

[commit]
	template = ~/.config/git/.gitmessage
[credential "https://github.com"]
	helper = /opt/homebrew/bin/gh auth git-credential

[credential "https://source.developers.google.com"]
	helper = gcloud.sh
[color "blame"]
	repeatedLines = bold 114
	highlightedLine = bold 226
	highlightedBoundary = bold 161
[coderabbit]
	machineId = cli/88a013c1cb39466287b4a9fee534ef17
